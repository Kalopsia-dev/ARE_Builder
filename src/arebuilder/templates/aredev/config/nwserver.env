# NWNEE Server Config Flags - Modify to your server needs
NWN_SERVERNAME="AREDev Test Server"
# If you change the port here, also change the port mapping in docker-compose.yml
NWN_PORT=5121
NWN_PUBLICSERVER=1
NWN_MAXCLIENTS=96
NWN_MINLEVEL=1
NWN_MAXLEVEL=30
NWN_PAUSEANDPLAY=0
NWN_PVP=2
NWN_SERVERVAULT=1
NWN_ELC=0
NWN_ILR=0
NWN_GAMETYPE=3
NWN_ONEPARTY=0
NWN_DIFFICULTY=3
NWN_AUTOSAVEINTERVAL=0
NWN_RELOADWHENEMPTY=0
# You may change these to whatever you like
NWN_PLAYERPASSWORD=aredev
NWN_DMPASSWORD=aredev
NWN_ADMINPASSWORD=aredev

# NWNXEE Logging Flags - 1 is the less verbose and 7 the most verbose
# To increase logging level for specific plugins use: NWNX_{PLUGIN}_LOG_LEVEL={Level}
# Example: NWNX_ADMINISTRATION_LOG_LEVEL=7
NWNX_CORE_LOG_LEVEL=6
#NWNX_ARELITH_LOG_LEVEL=7

# NWNXEE Disable All Plugins Flag - By default we need to disable each plugin ourselves
NWNX_CORE_SKIP_ALL=no

# NWNXEE Plugins Flags - Enable/disable the plugins you need here
# To disable a plugin you only need to add a line here: NWNX_{PLUGIN}_SKIP=yes
# Take into account that you might need extra settings for specific plugins
#NWNX_ADMINISTRATION_SKIP=yes
#NWNX_DAMAGE_SKIP=yes
NWNX_REDIS_SKIP=yes
#NWNX_PROFILER_SKIP=yes
#NWNX_TRACKING_SKIP=yes
NWNX_METRICS_INFLUXDB_SKIP=yes # required as of .36
#NWNX_JVM_SKIP=yes
#NWNX_LUA_SKIP=yes
#NWNX_MONO_SKIP=yes
#NWNX_WEBHOOK_SKIP=yes
#NWNX_SKILLRANKS_SKIP=yes
#NWNX_RACE_SKIP=yes
NWNX_SPELLCHECKER_SKIP=yes
NWNX_DOTNET_SKIP=yes

# NWNXEE SQL Plugin - Update with your database settings here. Make sure these match the settings in db.env
NWNX_SQL_TYPE=MYSQL
# Docker Compose resolves this host name from the db service name.
NWNX_SQL_HOST=db
NWNX_SQL_DATABASE=nwn
NWNX_SQL_USERNAME=aredev
NWNX_SQL_PASSWORD=aredevdbpass

# NWNXEE Redis Plugin
NWNX_REDIS_HOST=redis
NWNX_REDIS_PUBSUB_CHANNELS=sendmessage

# NWNXEE Ruby Plugin
NWNX_RUBY_PRELOAD_SCRIPT=/nwn/ruby/extern.rb

# Enable/disable individual tweaks
NWNX_TWEAKS_HIDE_CLASSES_ON_CHAR_LIST=yes
NWNX_TWEAKS_COMPARE_VARIABLES_WHEN_MERGING=no
NWNX_TWEAKS_DISABLE_SHADOWS=yes
NWNX_TWEAKS_DISABLE_PAUSE=yes
NWNX_TWEAKS_DISABLE_QUICKSAVE=yes
NWNX_TWEAKS_SNEAK_ATTACK_IGNORE_CRIT_IMMUNITY=no
NWNX_TWEAKS_HIDE_DMS_ON_CHAR_LIST=yes
NWNX_TWEAKS_STRIP_OVT_FROM_NOT_VISIBLE_OBJECT=yes
NWNX_ARELITH_DMG_RED=true

# NWNXEE Metrics Plugin
NWNX_SQL_QUERY_METRICS=no

# Optimisations
NWNX_OPTIMIZATIONS_ASYNC_LOG_FLUSH=yes
NWNX_OPTIMIZATIONS_CLIENT_GAMEOBJECT_UPDATE_TIME_LOADING=10000
NWNX_OPTIMIZATIONS_GAME_OBJECT_LOOKUP=yes
NWNX_OPTIMIZATIONS_LUO_LOOKUP=yes
NWNX_OPTIMIZATIONS_PLAYER_LOOKUP=yes
NWNX_OPTIMIZATIONS_RECONCILE_AUTOMAP_DATA=yes
NWNX_OPTIMIZATIONS_EVENT_MASTER_PRIORITY_QUEUE=yes
NWNX_OPTIMIZATIONS_GET_OBJECT_BY_TAG=yes
