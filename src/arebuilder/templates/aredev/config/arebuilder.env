# AREDev project settings
# BUILD_TARGET selects the <target>-resources checkout and are-dev-<target>.mod.
BUILD_TARGET=pgcc

# Use native for local Python builds or docker to run the packaged builder image.
BUILDER_BACKEND=native
BUILDER_IMAGE=kalopsiadev/arebuilder:latest
NWSERVER_IMAGE=dmhoodoo/aredevnwnxserver:latest

# Leave these blank to use auto-detection/native defaults.
# NWN_INSTALL_PATH is the host NWN install folder that contains data/ and bin/.
# NWN_HOME_PATH is the host NWN user folder that contains client hak/ and tlk/.
# Set absolute host paths here when running Dockerized AREDev.
NWN_INSTALL_PATH=
NWN_HOME_PATH=
